---
import Layout from '../layouts/SelfServiceLayout.astro';
import Icon from '../components/Icon.astro';
import PageHead from '../components/PageHead.astro';
import Drawer from '../components/Drawer.astro';
import { getCalendarEvents, getHolidays } from '@emela/shared/data';

const events = await getCalendarEvents();
const holidays = await getHolidays();
---
<Layout title="Calendrier — Espace personnel emela" page="calendrier">
<style is:global>
  .cal-bar { display:flex; align-items:center; justify-content:space-between; gap:var(--space-4); flex-wrap:wrap; margin-bottom:var(--space-5); }
  .cal-nav { display:flex; align-items:center; gap:var(--space-3); }
  .cal-label { font-family:var(--font-display); font-size:var(--text-lg); font-weight:700; min-width:180px; text-transform:capitalize; }
  .cal-nbtn { width:36px; height:36px; border:1px solid var(--border-default); background:var(--surface-paper); border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; cursor:pointer; color:var(--text-secondary); }
  .cal-nbtn:hover { border-color:var(--border-strong); color:var(--text-primary); }
  .cal-wrap { background:var(--surface-paper); border:1px solid var(--border-default); border-radius:var(--radius-lg); overflow:hidden; }

  /* Grille mois */
  .cal-dow { display:grid; grid-template-columns:repeat(7,1fr); border-bottom:1px solid var(--border-subtle); }
  .cal-dow div { padding:var(--space-3); text-align:center; font-size:var(--text-2xs); font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--text-tertiary); }
  .cal-grid { display:grid; grid-template-columns:repeat(7,1fr); }
  .cal-cell { min-height:104px; border-right:1px solid var(--border-subtle); border-bottom:1px solid var(--border-subtle); padding:var(--space-3); display:flex; flex-direction:column; gap:4px; }
  .cal-cell:nth-child(7n) { border-right:0; }
  .cal-cell.out { background:var(--sand-25); }
  .cal-cell.wk { background:var(--sand-50); }
  .cal-cell.hol { background:repeating-linear-gradient(135deg, var(--sand-50), var(--sand-50) 8px, var(--sand-100) 8px, var(--sand-100) 10px); }
  .cal-daynum { font-size:var(--text-sm); font-weight:600; color:var(--text-primary); display:flex; align-items:center; justify-content:space-between; }
  .cal-cell.out .cal-daynum { color:var(--text-tertiary); font-weight:500; }
  .cal-cell.wk .cal-daynum, .cal-cell.hol .cal-daynum { color:var(--text-tertiary); }
  .cal-today { width:24px; height:24px; border-radius:50%; background:var(--ink-800); color:#fff; display:inline-flex; align-items:center; justify-content:center; }
  .cal-holname { font-size:9px; color:var(--text-tertiary); font-weight:600; text-transform:uppercase; letter-spacing:.03em; }
  .cal-ev { font-size:var(--text-2xs); font-weight:600; padding:2px 6px; border-radius:var(--radius-xs); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .cal-ev.leave { background:var(--ink-100); color:var(--ink-800); }
  .cal-ev.pending { background:var(--warning-50); color:var(--warning-700); }
  .cal-ev.hol { background:var(--accent-50); color:var(--accent-700); }

  /* Année */
  .cal-year { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--space-5); padding:var(--space-6); }
  @media (max-width:860px){ .cal-year { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:520px){ .cal-year { grid-template-columns:1fr; } }
  .ym { }
  .ym h4 { font-size:var(--text-sm); font-weight:700; margin:0 0 var(--space-3); text-transform:capitalize; }
  .ym-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:1px; }
  .ym-d { aspect-ratio:1; display:flex; align-items:center; justify-content:center; font-size:10px; color:var(--text-secondary); border-radius:3px; }
  .ym-d.wk { color:var(--text-tertiary); background:var(--sand-50); }
  .ym-d.hol { background:var(--accent-100); color:var(--accent-700); font-weight:700; }
  .ym-d.ev { background:var(--ink-100); color:var(--ink-800); font-weight:700; }
  .ym-d.today { background:var(--ink-800); color:#fff; font-weight:700; }
  .ym-d.out { color:transparent; }

  /* Semaine */
  .cal-week { display:grid; grid-template-columns:repeat(7,1fr); }
  .cal-wcol { border-right:1px solid var(--border-subtle); min-height:280px; }
  .cal-wcol:last-child { border-right:0; }
  .cal-whead { padding:var(--space-4); text-align:center; border-bottom:1px solid var(--border-subtle); }
  .cal-whead .dow { font-size:var(--text-2xs); text-transform:uppercase; letter-spacing:.06em; color:var(--text-tertiary); font-weight:700; }
  .cal-whead .dn { font-family:var(--font-display); font-size:var(--text-lg); font-weight:700; margin-top:2px; }
  .cal-wcol.wk .cal-whead { background:var(--sand-50); }
  .cal-wcol.hol .cal-whead { background:var(--accent-50); }
  .cal-wbody { padding:var(--space-3); display:flex; flex-direction:column; gap:var(--space-3); }

  /* Jour */
  .cal-day { padding:var(--space-8); }
  .cal-day .big { font-family:var(--font-display); font-size:var(--text-3xl); font-weight:800; letter-spacing:-.02em; text-transform:capitalize; }
  .cal-day .agenda { margin-top:var(--space-6); display:flex; flex-direction:column; gap:var(--space-3); }

  .legend { display:flex; gap:var(--space-5); flex-wrap:wrap; margin-top:var(--space-5); font-size:var(--text-xs); color:var(--text-tertiary); }
  .legend span { display:inline-flex; align-items:center; gap:6px; }
  .legend i { width:12px; height:12px; border-radius:3px; display:inline-block; }
</style>

<main class="hr-page">
  <PageHead title="Calendrier" sub="Vos congés et absences. Week-ends et jours fériés grisés.">
    <Fragment slot="actions"><a class="em-btn em-btn--accent" data-drawer-open="drawer-conge" href="javascript:void(0)"><Icon name="i-plane" cls="ico-sm" />Demander un congé</a></Fragment>
  </PageHead>

  <div class="cal-bar">
    <div class="cal-nav">
      <button class="cal-nbtn" id="cal-prev" aria-label="Précédent"><Icon name="i-caretleft" cls="ico-sm" /></button>
      <button class="cal-nbtn" id="cal-next" aria-label="Suivant"><Icon name="i-caret" cls="ico-sm" /></button>
      <span class="cal-label" id="cal-label"></span>
      <button class="em-btn em-btn--secondary em-btn--sm" id="cal-today">Aujourd'hui</button>
    </div>
    <div class="em-btn-group" id="cal-views" role="tablist">
      <button class="em-btn em-btn--sm" data-view="day">Jour</button>
      <button class="em-btn em-btn--sm" data-view="week">Semaine</button>
      <button class="em-btn em-btn--sm is-active" data-view="month">Mois</button>
      <button class="em-btn em-btn--sm" data-view="year">Année</button>
    </div>
  </div>

  <div class="cal-wrap" id="cal-wrap"></div>

  <div class="legend">
    <span><i style="background:var(--sand-50);border:1px solid var(--border-default)"></i>Week-end</span>
    <span><i style="background:var(--accent-100)"></i>Jour férié</span>
    <span><i style="background:var(--ink-100)"></i>Congé validé</span>
    <span><i style="background:var(--warning-50);border:1px solid var(--warning-500)"></i>En attente</span>
  </div>
</main>

<!-- Drawer demande de congé -->
<div class="hr-scrim" id="hr-scrim"></div>
<Drawer id="drawer-conge" title="Demander un congé" sub="Votre demande sera transmise à votre manager.">
    <div class="em-field"><label class="em-field-label" for="dc-type">Type de congé</label><select class="em-select" id="dc-type"><option>Congé annuel — 18 j restants</option><option>Congé maladie — 5 j restants</option><option>Permission exceptionnelle — 2 j restants</option></select></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-5)">
      <div class="em-field"><label class="em-field-label" for="dc-from">Du</label><input class="em-input" id="dc-from" type="date" value="2026-08-10" /></div>
      <div class="em-field"><label class="em-field-label" for="dc-to">Au</label><input class="em-input" id="dc-to" type="date" value="2026-08-14" /></div>
    </div>
  <Fragment slot="foot">
    <button class="em-btn em-btn--secondary" data-drawer-close>Annuler</button>
    <button class="em-btn em-btn--primary" onclick="HrDrawer.close(); hrToast('Demande de congé transmise', true);">Envoyer la demande</button></Fragment>
</Drawer>
<script type="application/json" id="cal-data" set:html={JSON.stringify({ events, holidays })}></script>
<script is:inline>
(function () {
  var MONTHS = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
  var DOW = ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];
  var TODAY = new Date(2026, 5, 16);
  var CAL = JSON.parse(document.getElementById('cal-data').textContent);
  var HOL = {}; CAL.holidays.forEach(function (h) { HOL[h.date] = h.name; });
  var EVENTS = CAL.events.map(function (ev) { return { s: ev.start, e: ev.end, label: ev.label, cls: ev.kind }; });
  var state = { view:'month', ref:new Date(2026,5,16) };

  function key(d){ return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }
  function isWeekend(d){ var x=d.getDay(); return x===0||x===6; }
  function sameDay(a,b){ return a.getFullYear()===b.getFullYear()&&a.getMonth()===b.getMonth()&&a.getDate()===b.getDate(); }
  function evFor(d){ var k=key(d); return EVENTS.filter(function(ev){ return k>=ev.s && k<=ev.e; }); }
  function mondayIndex(d){ return (d.getDay()+6)%7; }

  function renderMonth(){
    var ref=state.ref, y=ref.getFullYear(), m=ref.getMonth();
    document.getElementById('cal-label').textContent = MONTHS[m]+' '+y;
    var first=new Date(y,m,1), lead=mondayIndex(first), total=new Date(y,m+1,0).getDate();
    var html='<div class="cal-dow">'+DOW.map(function(d){return '<div>'+d+'</div>';}).join('')+'</div><div class="cal-grid">';
    var cells = Math.ceil((lead+total)/7)*7;
    for(var i=0;i<cells;i++){
      var dayNum=i-lead+1;
      var d=new Date(y,m,dayNum);
      var out = dayNum<1 || dayNum>total;
      var k=key(d), hol=HOL[k], wknd=isWeekend(d);
      var cls='cal-cell'+(out?' out':'')+(!out&&hol?' hol':(!out&&wknd?' wk':''));
      var inner='';
      if(!out){
        var tnum = sameDay(d,TODAY) ? '<span class="cal-today">'+dayNum+'</span>' : dayNum;
        inner='<div class="cal-daynum">'+tnum+'</div>';
        if(hol) inner+='<div class="cal-holname">'+hol+'</div>';
        evFor(d).forEach(function(ev){ inner+='<div class="cal-ev '+ev.cls+'">'+ev.label+'</div>'; });
      }
      html+='<div class="'+cls+'">'+inner+'</div>';
    }
    html+='</div>';
    return html;
  }

  function renderYear(){
    var y=state.ref.getFullYear();
    document.getElementById('cal-label').textContent = ''+y;
    var html='<div class="cal-year">';
    for(var m=0;m<12;m++){
      html+='<div class="ym"><h4>'+MONTHS[m]+'</h4><div class="ym-grid">';
      var first=new Date(y,m,1), lead=mondayIndex(first), total=new Date(y,m+1,0).getDate();
      for(var i=0;i<lead;i++) html+='<div class="ym-d out">0</div>';
      for(var dn=1;dn<=total;dn++){
        var d=new Date(y,m,dn), k=key(d);
        var c='ym-d';
        if(sameDay(d,TODAY)) c+=' today';
        else if(HOL[k]) c+=' hol';
        else if(evFor(d).length) c+=' ev';
        else if(isWeekend(d)) c+=' wk';
        html+='<div class="'+c+'">'+dn+'</div>';
      }
      html+='</div></div>';
    }
    html+='</div>';
    return html;
  }

  function renderWeek(){
    var ref=state.ref, start=new Date(ref); start.setDate(ref.getDate()-mondayIndex(ref));
    var endd=new Date(start); endd.setDate(start.getDate()+6);
    document.getElementById('cal-label').textContent = start.getDate()+' '+MONTHS[start.getMonth()].slice(0,4)+'. – '+endd.getDate()+' '+MONTHS[endd.getMonth()].slice(0,4)+'. '+endd.getFullYear();
    var html='<div class="cal-week">';
    for(var i=0;i<7;i++){
      var d=new Date(start); d.setDate(start.getDate()+i);
      var k=key(d), hol=HOL[k], wknd=isWeekend(d);
      html+='<div class="cal-wcol'+(hol?' hol':(wknd?' wk':''))+'">';
      html+='<div class="cal-whead"><div class="dow">'+DOW[i]+'</div><div class="dn">'+(sameDay(d,TODAY)?'<span class="cal-today" style="width:34px;height:34px">'+d.getDate()+'</span>':d.getDate())+'</div></div>';
      html+='<div class="cal-wbody">';
      if(hol) html+='<div class="cal-ev hol">'+hol+'</div>';
      evFor(d).forEach(function(ev){ html+='<div class="cal-ev '+ev.cls+'">'+ev.label+'</div>'; });
      html+='</div></div>';
    }
    html+='</div>';
    return html;
  }

  function renderDay(){
    var d=state.ref, k=key(d), hol=HOL[k], wknd=isWeekend(d);
    document.getElementById('cal-label').textContent = MONTHS[d.getMonth()]+' '+d.getFullYear();
    var evs=evFor(d);
    var tags='';
    if(wknd) tags+='<span class="em-badge em-badge--neutral"><span class="em-badge-dot"></span>Week-end</span> ';
    if(hol) tags+='<span class="em-badge em-badge--accent"><span class="em-badge-dot"></span>Férié — '+hol+'</span>';
    var agenda='';
    if(evs.length){ evs.forEach(function(ev){ agenda+='<div class="hr-list-row" style="border:1px solid var(--border-default);border-radius:var(--radius-md)"><span class="hr-list-ic leave"><svg class="ico-sm"><use href="#i-plane"/></svg></span><div class="hr-list-main"><div class="hr-list-tt">'+ev.label+'</div><div class="hr-list-meta">'+(ev.cls==='pending'?'En attente de validation':'Validé')+'</div></div></div>'; }); }
    else if(!hol && !wknd){ agenda='<div style="color:var(--text-tertiary);font-size:var(--text-sm)">Aucun événement ce jour — journée travaillée.</div>'; }
    else { agenda='<div style="color:var(--text-tertiary);font-size:var(--text-sm)">Jour non travaillé.</div>'; }
    return '<div class="cal-day"><div class="big">'+DOW[mondayIndex(d)]+'. '+d.getDate()+' '+MONTHS[d.getMonth()]+'</div><div style="margin-top:var(--space-4);display:flex;gap:var(--space-3);flex-wrap:wrap">'+tags+'</div><div class="agenda">'+agenda+'</div></div>';
  }

  function render(){
    var wrap=document.getElementById('cal-wrap');
    if(state.view==='month') wrap.innerHTML=renderMonth();
    else if(state.view==='year') wrap.innerHTML=renderYear();
    else if(state.view==='week') wrap.innerHTML=renderWeek();
    else wrap.innerHTML=renderDay();
  }
  function step(dir){
    var d=state.ref;
    if(state.view==='month') state.ref=new Date(d.getFullYear(),d.getMonth()+dir,1);
    else if(state.view==='year') state.ref=new Date(d.getFullYear()+dir,d.getMonth(),1);
    else if(state.view==='week'){ state.ref=new Date(d); state.ref.setDate(d.getDate()+7*dir); }
    else { state.ref=new Date(d); state.ref.setDate(d.getDate()+dir); }
    render();
  }
  document.getElementById('cal-prev').addEventListener('click',function(){step(-1);});
  document.getElementById('cal-next').addEventListener('click',function(){step(1);});
  document.getElementById('cal-today').addEventListener('click',function(){ state.ref=new Date(2026,5,16); render(); });
  document.getElementById('cal-views').addEventListener('click',function(e){ var b=e.target.closest('button'); if(!b) return; state.view=b.getAttribute('data-view'); document.querySelectorAll('#cal-views button').forEach(function(x){x.classList.toggle('is-active',x===b);}); render(); });
  render();
})();
</script>

</Layout>
