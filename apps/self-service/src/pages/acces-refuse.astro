---
import '@emela/design-system/index.css';
import Sprite from '../components/Sprite.astro';
import Icon from '../components/Icon.astro';

export const prerender = false;
// Affichée à un utilisateur authentifié SANS dossier salarié (gate ESS du middleware).
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/assets/lanem-logo.webp" />
    <title>Accès réservé — Espace personnel SIRH</title>
  </head>
  <body style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--sand-50);padding:var(--space-6)">
    <Sprite />
    <div style="max-width:460px;text-align:center;background:var(--surface-paper);border:1px solid var(--border-default);border-radius:var(--radius-lg);padding:var(--space-9) var(--space-8)">
      <span style="display:inline-flex;width:52px;height:52px;align-items:center;justify-content:center;border-radius:50%;background:var(--error-50);color:var(--error-700)"><Icon name="i-lock" cls="ico-lg" /></span>
      <h1 style="font-family:var(--font-display);font-size:var(--text-lg);margin:var(--space-5) 0 var(--space-3)">Espace réservé aux salariés</h1>
      <p style="font-size:var(--text-sm);color:var(--text-secondary);line-height:1.6;margin:0 0 var(--space-7)">
        Aucun dossier salarié actif n'est rattaché à votre compte. L'espace personnel
        est réservé aux salariés de la LaNEM. Si vous pensez qu'il s'agit d'une erreur,
        contactez le service RH.
      </p>
      <form method="POST" action="/api/logout">
        <button type="submit" class="em-btn em-btn--secondary"><Icon name="i-x" cls="ico-sm" />Se déconnecter</button>
      </form>
    </div>
  </body>
</html>
