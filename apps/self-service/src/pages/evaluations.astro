---
import Layout from '../layouts/SelfServiceLayout.astro';
import Icon from '../components/Icon.astro';
import PageHead from '../components/PageHead.astro';
import Card from '../components/Card.astro';

// Descopé de la v1 (décision F4) : l'entretien annuel d'évaluation RH n'est pas
// encore construit côté back. Il sera développé intégralement dans benin_hr lors
// d'un round ultérieur (doctype Entretien annuel + workflow auto-éval → synthèse
// manager → contresignature). teaching_eval = éval pédagogique étudiante, source
// non pertinente ici. On rend un état honnête « à venir ».
---
<Layout title="Mes évaluations — Espace personnel emela" page="evaluations">
<main class="hr-page">
  <PageHead title="Mes évaluations" sub="Entretien annuel d'évaluation." />
  <Card>
    <div style="padding:var(--space-9) var(--space-7);text-align:center;color:var(--text-tertiary)">
      <Icon name="i-star" cls="ico-lg" />
      <h2 style="margin:var(--space-4) 0 var(--space-2);font-size:var(--text-md);color:var(--text-secondary)">Module à venir</h2>
      <p style="font-size:var(--text-sm);max-width:42ch;margin:0 auto">
        L'entretien annuel d'évaluation sera disponible prochainement. Vous y préparerez
        votre auto-évaluation et consulterez vos comptes-rendus.
      </p>
    </div>
  </Card>
</main>
</Layout>
