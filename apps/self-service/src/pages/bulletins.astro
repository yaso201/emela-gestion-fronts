---
import Layout from '../layouts/SelfServiceLayout.astro';
import Icon from '../components/Icon.astro';
import StatusBadge from '../components/StatusBadge.astro';
import PageHead from '../components/PageHead.astro';
import { getPayslips, fcfa } from '@emela/shared/data';

const payslips = await getPayslips();
const y2026 = payslips.filter((p) => p.year === 2026);
const last = payslips[0];
const nf = (n: number) => new Intl.NumberFormat('fr-FR').format(n);
const cumulNet = y2026.reduce((s, p) => s + p.net, 0);
const cumulITS = y2026.reduce((s, p) => s + p.incomeTax, 0);
const lastMM = last.id.split('-').slice(1).reverse().join('/');
const moisDe = y2026[y2026.length - 1].period.split(' ')[0].toLowerCase();
const moisA = y2026[0].period.split(' ')[0].toLowerCase();
const PS: Record<string, { v: string; l: string }> = {
  available: { v: 'success', l: 'Disponible' },
  archived:  { v: 'neutral', l: 'Archivé' },
};
---
<Layout title="Mes bulletins de paie — Espace personnel emela" page="bulletins">
<style>
  .bp-kpis { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--space-4); margin-bottom:var(--space-8); }
  @media (max-width:720px){ .bp-kpis { grid-template-columns:1fr; } }
  .bp-yearbar { display:flex; align-items:center; gap:var(--space-4); margin-bottom:var(--space-5); }
  .bp-yearbar .yr { font-family:var(--font-display); font-size:var(--text-lg); font-weight:700; }
  .num { font-family:var(--font-mono); font-variant-numeric:tabular-nums; }
</style>



<main class="hr-page">
  <PageHead title="Mes bulletins de paie" sub="Vos bulletins mensuels. Les montants sont calculés et figés côté serveur." />

  <section class="bp-kpis">
    <div class="em-kpi">
      <span class="em-kpi-label">Dernier net perçu</span>
      <span class="em-kpi-value num">{nf(last.net)}<span class="em-kpi-value-unit">F · {lastMM}</span></span>
      <span class="em-kpi-trend em-kpi-trend--up"><Icon name="i-trend" cls="ico-sm" />stable vs avril</span>
    </div>
    <div class="em-kpi">
      <span class="em-kpi-label">Cumul net 2026</span>
      <span class="em-kpi-value num">{nf(cumulNet)}<span class="em-kpi-value-unit">F</span></span>
      <span class="em-kpi-meta">{y2026.length} bulletins · {moisDe} → {moisA}</span>
    </div>
    <div class="em-kpi">
      <span class="em-kpi-label">Cumul ITS retenu 2026</span>
      <span class="em-kpi-value num">{nf(cumulITS)}<span class="em-kpi-value-unit">F</span></span>
      <span class="em-kpi-meta">Impôt sur traitements &amp; salaires</span>
    </div>
  </section>

  <div class="bp-yearbar">
    <span class="yr">2026</span>
    <span class="em-badge em-badge--neutral">Exercice en cours</span>
  </div>

  <div class="em-table-wrap">
    <table class="em-table">
      <thead>
        <tr><th>Période</th><th>Émis le</th><th class="em-cell-num">Salaire brut</th><th class="em-cell-num">Retenues</th><th class="em-cell-num">Net à payer</th><th>Statut</th><th style="text-align:right">Actions</th></tr>
      </thead>
      <tbody>
        {payslips.map((p) => (
          <tr>
            <td><b>{p.period}</b></td><td>{p.issuedOn}</td>
            <td class="em-cell-num num">{fcfa(p.gross)}</td><td class="em-cell-num num">{fcfa(p.deductions)}</td><td class="em-cell-num num"><b>{fcfa(p.net)}</b></td>
            <td><StatusBadge variant={PS[p.status].v}>{PS[p.status].l}</StatusBadge></td>
            <td style="text-align:right;white-space:nowrap"><a class="em-btn em-btn--secondary em-btn--sm" href={`/bulletin?id=${p.id}`}>Voir</a> <button class="em-btn em-btn--ghost em-btn--sm" onclick={`downloadBulletin(${JSON.stringify(p.id)})`}><Icon name="i-download" cls="ico-sm" />PDF</button></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <p style="font-size:var(--text-xs);color:var(--text-tertiary);margin-top:var(--space-5)">Le bulletin de décembre intègre la prime de fin d'année (13<sup>e</sup> mois conventionnel).</p>
</main>

<script is:inline>
  // Téléchargement du bulletin via le proxy /api/bulletin/pdf (permission self-scope back).
  window._dlBusy = window._dlBusy || {};
  window.downloadBulletin = async function (id) {
    if (window._dlBusy[id]) return;       // garde double-clic
    window._dlBusy[id] = true;
    try {
      var res = await fetch('/api/bulletin/pdf?id=' + encodeURIComponent(id));
      if (!res.ok) { var d = await res.json().catch(function () { return {}; }); hrToast(d.error || 'Téléchargement impossible', false); return; }
      var blob = await res.blob();
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a'); a.href = url; a.download = 'bulletin-' + id + '.pdf';
      document.body.appendChild(a); a.click(); a.remove();
      setTimeout(function () { URL.revokeObjectURL(url); }, 1000);
      hrToast('Bulletin téléchargé', true);
    } catch (e) { hrToast('Erreur réseau', false); }
    finally { window._dlBusy[id] = false; }
  };
</script>

</Layout>
