---
import Layout from '../layouts/SelfServiceLayout.astro';
import Icon from '../components/Icon.astro';
import PageHead from '../components/PageHead.astro';
import { getMyAttestations } from '@emela/shared/data';
import type { MyAttestation } from '@emela/shared/data';

let attestations: MyAttestation[] = [];
let fetchError = false;
try {
  attestations = await getMyAttestations();
} catch {
  fetchError = true;
}

const TYPE_LABEL: Record<string, string> = {
  Travail: 'Attestation de travail',
  Assiduite: "Attestation d'assiduité",
  'Mission enseignement': "Attestation de mission d'enseignement",
};
const STATUS: Record<string, { label: string; variant: string }> = {
  Demande: { label: 'En traitement', variant: 'warning' },
  Delivree: { label: 'Délivrée', variant: 'success' },
  Rejete: { label: 'Refusée', variant: 'error' },
};
const REQUESTABLE = [
  { type: 'Travail', label: 'Attestation de travail' },
  { type: 'Assiduite', label: "Attestation d'assiduité" },
  { type: 'Mission enseignement', label: "Mission d'enseignement" },
];
---
<Layout title="Mes documents — Espace personnel emela" page="documents">
<style>
  .doc-row { display:flex; align-items:center; gap:var(--space-4); padding:var(--space-5) var(--space-6); border-top:1px solid var(--border-subtle); }
  .doc-row:first-child { border-top:0; }
  .doc-row .em-doc-icon { flex-shrink:0; }
  .doc-row .main { flex:1; min-width:0; }
  .doc-row .t { font-size:var(--text-sm); font-weight:600; }
  .doc-row .m { font-size:var(--text-xs); color:var(--text-tertiary); margin-top:1px; }
  .doc-row .side { display:flex; align-items:center; gap:var(--space-3); flex-shrink:0; }
</style>

<main class="hr-page">
  <PageHead title="Mes documents RH" sub="Vos attestations délivrées par le service RH, à télécharger." />

  <p class="hr-section-label">Mes attestations</p>
  <div class="em-card" style="margin-bottom:var(--space-9)">
    {fetchError ? (
      <div style="padding:var(--space-8);text-align:center;color:var(--text-tertiary)"><Icon name="i-info" cls="ico-lg" /><p style="margin-top:var(--space-2);font-size:var(--text-sm)">Impossible de charger vos documents pour le moment.</p></div>
    ) : attestations.length === 0 ? (
      <div style="padding:var(--space-8);text-align:center;color:var(--text-tertiary)"><Icon name="i-badge" cls="ico-lg" /><p style="margin-top:var(--space-2);font-size:var(--text-sm)">Aucune attestation pour le moment. Demandez-en une ci-dessous.</p></div>
    ) : attestations.map((a) => {
      const st = STATUS[a.status] ?? { label: a.status, variant: 'neutral' };
      return (
        <div class="doc-row">
          <span class="em-doc-icon em-doc-icon--accent"><Icon name="i-badge" cls="ico" /></span>
          <div class="main"><div class="t">{TYPE_LABEL[a.attestation_type] ?? a.attestation_type}</div><div class="m">Réf. {a.name}{a.request_date ? ` · demandée le ${a.request_date}` : ''}</div></div>
          <div class="side">
            <span class={`em-badge em-badge--${st.variant}`}>{st.label}</span>
            {a.status === 'Delivree' && (
              <button class="em-btn em-btn--secondary em-btn--sm" onclick={`downloadAttestation(${JSON.stringify(a.name)})`}><Icon name="i-download" cls="ico-sm" />PDF</button>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <p class="hr-section-label">Demander un document</p>
  <div class="em-card">
    <div class="em-card-body" style="display:flex;align-items:center;justify-content:space-between;gap:var(--space-6);flex-wrap:wrap">
      <div style="display:flex;align-items:center;gap:var(--space-5)">
        <span class="em-doc-icon em-doc-icon--accent"><Icon name="i-badge" cls="ico" /></span>
        <div>
          <div style="font-size:var(--text-base);font-weight:600;color:var(--text-primary)">Besoin d'une attestation ?</div>
          <div style="font-size:var(--text-sm);color:var(--text-secondary);margin-top:2px">Demande adressée au service RH — délai indicatif 48 h ouvrées.</div>
        </div>
      </div>
      <div style="display:flex;gap:var(--space-3);flex-wrap:wrap">
        {REQUESTABLE.map((r) => (
          <button class="em-btn em-btn--secondary" onclick={`requestAttestation(${JSON.stringify(r.type)})`}>{r.label}</button>
        ))}
      </div>
    </div>
  </div>

  <div class="em-alert em-alert--neutral" style="margin-top:var(--space-7)">
    <span class="em-alert-icon"><Icon name="i-info" cls="ico-sm" /></span>
    <div class="em-alert-body"><span class="em-alert-text">Vos <b>bulletins de paie</b> sont consultables et téléchargeables depuis l'onglet <a href="/bulletins" style="color:var(--ink-700);font-weight:600">Mes bulletins</a>.</span></div>
  </div>
</main>

<script is:inline>
  window._dlBusy = window._dlBusy || {};
  window.downloadAttestation = async function (id) {
    if (window._dlBusy[id]) return;
    window._dlBusy[id] = true;
    try {
      var res = await fetch('/api/attestation/pdf?id=' + encodeURIComponent(id));
      if (!res.ok) { var d = await res.json().catch(function () { return {}; }); hrToast(d.error || 'Téléchargement impossible', false); return; }
      var blob = await res.blob();
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a'); a.href = url; a.download = 'attestation-' + id + '.pdf';
      document.body.appendChild(a); a.click(); a.remove();
      setTimeout(function () { URL.revokeObjectURL(url); }, 1000);
      hrToast('Attestation téléchargée', true);
    } catch (e) { hrToast('Erreur réseau', false); }
    finally { window._dlBusy[id] = false; }
  };
  var _reqBusy = false;
  window.requestAttestation = async function (type) {
    if (_reqBusy) return;
    _reqBusy = true;
    try {
      var res = await fetch('/api/requests/attestation', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ attestation_type: type }),
      });
      var d = await res.json().catch(function () { return {}; });
      if (res.ok) { hrToast('Demande envoyée au service RH', true); setTimeout(function () { location.reload(); }, 800); }
      else { hrToast(d.error || 'Échec de la demande', false); }
    } catch (e) { hrToast('Erreur réseau', false); }
    finally { _reqBusy = false; }
  };
</script>
</Layout>
