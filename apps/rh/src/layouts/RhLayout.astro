---
import '@emela/design-system/index.css';
import '../styles/shell.css';
import Sprite from '../components/Sprite.astro';
import Icon from '../components/Icon.astro';
import { getProfiles, getFullName } from '@emela/shared/session';

interface Props {
  title: string;
  /** Clé de page active (ex. "cockpit", "personnel"). */
  page?: string;
}
const { title, page = '' } = Astro.props;

// Profils RÉELS de l'utilisateur (dérivés des rôles back, posés par le middleware).
const profiles = getProfiles();
const canSee = (roles: string) => roles.split(/\s+/).some((r) => profiles.includes(r));

const PROFILE_LABELS: Record<string, string> = {
  manager: 'Manager', gest_rh: 'Gestionnaire RH', paie: 'Responsable paie',
  finance: 'Finance', dir: 'Direction', admin: 'Admin technique', gestion_sm: 'Gestion système',
};
const fullName = getFullName();
// Libellé = profil le plus privilégié (pas le premier de la liste).
const PROFILE_PRIORITY = ['admin', 'dir', 'gestion_sm', 'finance', 'paie', 'gest_rh', 'manager'];
const primary = PROFILE_PRIORITY.find((p) => profiles.includes(p)) ?? '';
const profileLabel = primary ? PROFILE_LABELS[primary] ?? '' : '';
const initials = (fullName || 'RH').split(/\s+/).filter(Boolean).slice(0, 2).map((w) => w[0]?.toUpperCase() ?? '').join('') || 'RH';

// Navigation groupée — chaque item porte ses profils autorisés.
const NAV = [
  { group: 'Pilotage', children: [
    { item: 'Tableau de bord', icon: 'i-grid', page: 'cockpit', href: '/cockpit', roles: 'manager gest_rh dir admin' },
  ]},
  { group: 'Personnel', children: [
    { item: 'Annuaire', icon: 'i-users', page: 'personnel', href: '/personnel', roles: 'gest_rh manager dir admin' },
    { item: 'Demandes à valider', icon: 'i-list', page: 'demandes', href: '/demandes', roles: 'manager gest_rh dir admin' },
    { item: 'Recrutement', icon: 'i-target', page: 'recrutement', href: '/recrutement', roles: 'manager gest_rh dir admin' },
    { item: 'Contrats', icon: 'i-doc', page: 'contrats', href: '/contrats', roles: 'gest_rh paie dir admin' },
    { item: 'Bénéficiaires externes', icon: 'i-building', page: 'beneficiaires-externes', href: '/beneficiaires-externes', roles: 'gest_rh dir admin' },
    // Évaluations (appréciation RH) descopé de la v1 — sera construit dans benin_hr (round ultérieur).
    { item: 'Séparations', icon: 'i-door', page: 'separations', href: '/separations', roles: 'gest_rh dir admin' },
  ]},
  { group: 'Paie', children: [
    { item: 'Cycle de paie', icon: 'i-coins', page: 'paie', href: '/paie', roles: 'paie finance dir admin' },
    { item: 'Validations', icon: 'i-shieldcheck', page: 'validation', href: '/validation', roles: 'manager finance dir admin', counter: '2' },
    { item: 'Déclarations', icon: 'i-megaphone', page: 'declarations', href: '/declarations', roles: 'paie gest_rh dir admin' },
    { item: 'Factures externes', icon: 'i-wallet', page: 'factures-externes', href: '/factures-externes', roles: 'gest_rh dir admin' },
  ]},
  { group: 'Documents', children: [
    { item: 'Modèles de documents', icon: 'i-stamp', page: 'modeles', href: '/modeles', roles: 'gest_rh paie dir admin gestion_sm' },
  ]},
  { group: 'Administration', children: [
    { item: 'Onboarding & accès', icon: 'i-users', page: 'onboarding', href: '/onboarding', roles: 'admin gestion_sm' },
    { item: 'Audit des accès', icon: 'i-eye', page: 'audit-acces', href: '/audit-acces', roles: 'admin dir' },
    { item: 'Paramètres', icon: 'i-sliders', page: 'parametres', href: '/parametres', roles: 'admin gestion_sm' },
  ]},
];

type NavRow =
  | { type: 'label'; label: string }
  | { type: 'item'; item: string; icon: string; page: string; href: string; roles: string; counter?: string };
const navRows: NavRow[] = [];
for (const node of NAV) {
  const visible = node.children.filter((c) => canSee(c.roles));
  if (!visible.length) continue; // groupe masqué si aucun item autorisé
  navRows.push({ type: 'label', label: node.group });
  for (const c of visible) navRows.push({ type: 'item', ...c });
}
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/assets/lanem-logo.webp" />
    <title>{title}</title>
  </head>
  <body data-page={page} data-profiles={profiles.join(' ')}>
    <Sprite />

    <!-- Barre mobile (< 900px) -->
    <div class="nav-mbar">
      <button class="nav-burger" aria-label="Menu" data-nav-toggle><Icon name="i-list" /></button>
      <span class="mark">emela<span>.</span></span>
    </div>

    <!-- Barre latérale (rendue côté serveur) -->
    <aside class="nav-side">
      <a class="nav-brand" href="/cockpit"><span class="mark">emela<span>.</span></span><span class="ctx">RH &amp; Paie</span></a>

      <nav class="nav-scroll">
        {navRows.map((row) => row.type === 'label' ? (
          <div class="nav-grouplabel">{row.label}</div>
        ) : (
          <a class:list={["nav-item", { "is-active": row.page === page }]} data-page={row.page} data-roles={row.roles} href={row.href}>
            <Icon name={row.icon} />
            <span class="lbl">{row.item}</span>
            {row.counter && <span class="em-counter">{row.counter}</span>}
          </a>
        ))}
      </nav>

      <div class="nav-user">
        <span class="av">{initials}</span>
        <span><span class="nm">{fullName}</span><span class="rl">{profileLabel}</span></span>
      </div>
    </aside>

    <div class="nav-scrim" data-nav-close></div>

    <slot />

    <script is:inline src="/scripts/shell.js"></script>
  </body>
</html>
