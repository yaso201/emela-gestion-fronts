---
import Layout from '../layouts/RhLayout.astro';
import Icon from '../components/Icon.astro';
import PageHead from '../components/PageHead.astro';
import Card from '../components/Card.astro';

// Descopé de la v1 (décision F4) : l'appréciation RH (entretien annuel) n'est pas
// encore construite côté back. Elle sera développée intégralement dans benin_hr lors
// d'un round ultérieur (doctype Entretien annuel + workflow auto-éval → synthèse
// manager → contresignature). teaching_eval = éval pédagogique étudiante, hors sujet.
---
<Layout title="Évaluations — emela RH" page="evaluations">
<main class="hr-page">
  <PageHead title="Évaluations" sub="Campagnes d'entretien annuel et comptes-rendus." />
  <Card>
    <div style="padding:var(--space-9) var(--space-7);text-align:center;color:var(--text-tertiary)">
      <Icon name="i-star" cls="ico-lg" />
      <h2 style="margin:var(--space-4) 0 var(--space-2);font-size:var(--text-md);color:var(--text-secondary)">Module à venir</h2>
      <p style="font-size:var(--text-sm);max-width:46ch;margin:0 auto">
        La gestion des entretiens annuels d'évaluation (campagnes, auto-évaluations,
        comptes-rendus et contresignatures) sera disponible prochainement.
      </p>
    </div>
  </Card>
</main>
</Layout>
